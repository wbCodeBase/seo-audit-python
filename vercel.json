{
  "version": 2,
  "builds": [
    { "src": "api/*.py", "use": "@vercel/python" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "functions": {
    "api/ai_rank.py":    { "maxDuration": 60 },
    "api/audit_run.py":  { "maxDuration": 60 },
    "api/audit_start.py":{ "maxDuration": 60 }
  },
  "routes": [
    { "src": "/api/audit_start", "dest": "/api/audit_start.py" },
    { "src": "/api/audit_poll",  "dest": "/api/audit_poll.py" },
    { "src": "/api/audit_run",   "dest": "/api/audit_run.py" },
    { "src": "/api/send_email",  "dest": "/api/send_email.py" },
    { "src": "/api/ai_rank",     "dest": "/api/ai_rank.py" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
